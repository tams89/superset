# Copy to .env and adjust to your environment.

# Target repo the scanner inspects (filesystem path)
VULN_BOT_REPO_PATH=/home/ubuntu/repos/superset

# Used in Devin prompts; referenced when opening issues
VULN_BOT_REPO_SLUG=tams89/superset
VULN_BOT_DEFAULT_BASE_BRANCH=master

# State store
VULN_BOT_DATABASE_URL=sqlite+aiosqlite:///./vuln_bot.db

# Devin API — leave DEVIN_API_KEY empty and DRY_RUN=true for demos
VULN_BOT_DEVIN_API_BASE=https://api.devin.ai/v1
VULN_BOT_DEVIN_API_KEY=
VULN_BOT_DEVIN_SESSION_PLAYBOOK=
VULN_BOT_DRY_RUN=true
VULN_BOT_MAX_CONCURRENT_SESSIONS=3

# GitHub webhook
VULN_BOT_GITHUB_WEBHOOK_SECRET=

# Scheduler
VULN_BOT_SCAN_INTERVAL_SECONDS=21600
VULN_BOT_SCHEDULER_ENABLED=true

# Observability
VULN_BOT_LOG_LEVEL=INFO
